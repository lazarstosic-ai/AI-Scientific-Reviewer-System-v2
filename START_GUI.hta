<!doctype html>
<html>
  <head>
    <meta http-equiv="x-ua-compatible" content="IE=edge" />
    <title>AI Scientific Reviewer System</title>
    <hta:application
      id="aiReviewerLauncher"
      applicationname="AI Scientific Reviewer System"
      border="thin"
      caption="yes"
      maximizebutton="no"
      minimizebutton="yes"
      scroll="no"
      singleinstance="yes"
      sysmenu="yes"
      windowstate="normal"
    />
    <style>
      body {
        margin: 0;
        padding: 28px;
        font-family: Arial, Helvetica, sans-serif;
        color: #171717;
        background: #f7f7f5;
      }

      h1 {
        margin: 0 0 14px;
        font-size: 25px;
      }

      p {
        font-size: 15px;
        line-height: 1.45;
      }

      button {
        width: 100%;
        min-height: 46px;
        margin-top: 16px;
        border: 0;
        border-radius: 6px;
        background: #111;
        color: white;
        font-size: 15px;
        font-weight: bold;
        cursor: pointer;
      }

      .secondary {
        background: #efefea;
        color: #171717;
        border: 1px solid #d8d8d0;
      }

      #status {
        margin-top: 16px;
        padding: 12px;
        border-radius: 6px;
        background: #f2f2ee;
        font-size: 14px;
      }

      code {
        background: #eeeeea;
        padding: 2px 4px;
        border-radius: 4px;
      }
    </style>
    <script language="javascript">
      var shell = new ActiveXObject("WScript.Shell");
      var fso = new ActiveXObject("Scripting.FileSystemObject");
      var folder = fso.GetParentFolderName(unescape(document.location.pathname).replace(/^\/+/, "").replace(/\//g, "\\"));
      var appUrl = "http://127.0.0.1:8000";

      function setStatus(message) {
        document.getElementById("status").innerText = message;
      }

      function startBackend() {
        var cmd = folder + "\\START_HERE.cmd";
        var command = '%ComSpec% /c start "AI Scientific Reviewer System" "' + cmd + '"';
        setStatus("Starting backend. Leave the PowerShell window open.");
        shell.Run(command, 1, false);
        window.setTimeout(openApp, 10000);
      }

      function openApp() {
        shell.Run(appUrl, 1, false);
        setStatus("Opening " + appUrl);
      }
    </script>
  </head>
  <body>
    <h1>AI Scientific Reviewer System</h1>
    <p>Click <strong>Start backend and open app</strong>. This launcher can start PowerShell because it is a Windows HTA application, not a restricted browser page.</p>
    <p>Keep the PowerShell window open while using the reviewer system. The app runs at <code>http://127.0.0.1:8000</code>.</p>
    <button onclick="startBackend()">Start backend and open app</button>
    <button class="secondary" onclick="openApp()">Open app only</button>
    <div id="status">Ready.</div>
  </body>
</html>
